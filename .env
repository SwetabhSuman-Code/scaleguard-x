# ─── Database ───────────────────────────────────────────────────
POSTGRES_HOST=postgres_db
POSTGRES_PORT=5432
POSTGRES_USER=scaleguard
POSTGRES_PASSWORD=scaleguard_secret
POSTGRES_DB=scaleguard

# ─── Redis ──────────────────────────────────────────────────────
REDIS_HOST=redis_queue
REDIS_PORT=6379

# ─── API Gateway ────────────────────────────────────────────────
API_GATEWAY_HOST=api_gateway
API_GATEWAY_PORT=8000

# ─── Ingestion Service ──────────────────────────────────────────
INGESTION_HOST=ingestion_service
INGESTION_PORT=8001

# ─── Metrics Stream ─────────────────────────────────────────────
METRICS_STREAM_KEY=metrics_stream
INGESTION_BATCH_SIZE=100
INGESTION_INTERVAL=2

# ─── Anomaly Engine ─────────────────────────────────────────────
ANOMALY_CPU_THRESHOLD=85.0
ANOMALY_LATENCY_THRESHOLD=500.0
ANOMALY_MEMORY_THRESHOLD=90.0
ANOMALY_RUN_INTERVAL=10

# ─── Prediction Engine ──────────────────────────────────────────
PREDICTION_HORIZON_MINUTES=10
PREDICTION_HISTORY_MINUTES=60
PREDICTION_RUN_INTERVAL=30

# ─── Autoscaler ─────────────────────────────────────────────────
AUTOSCALER_MIN_WORKERS=1
AUTOSCALER_MAX_WORKERS=8
AUTOSCALER_SCALE_UP_THRESHOLD=0.75
AUTOSCALER_SCALE_DOWN_THRESHOLD=0.35
AUTOSCALER_RUN_INTERVAL=15
WORKER_SERVICE_NAME=scaleguard-x-worker_cluster

# ─── Alerting ───────────────────────────────────────────────────
ALERT_WEBHOOK_URL=
ALERT_EMAIL_ENABLED=false

# ─── Agent ──────────────────────────────────────────────────────
AGENT_INTERVAL=5
NODE_ID=
